# mock = run without backend. real = call your backend.
VITE_API_MODE=mock
VITE_API_BASE_URL=http://localhost:4000
VITE_WS_URL=http://localhost:4000
# embedded = app owns login UI. host = larger site owns auth/session and uses cookies or injected access token.
VITE_AUTH_PROVIDER_MODE=embedded
VITE_ROUTING_BASENAME=/
